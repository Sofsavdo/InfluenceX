# ---- Umumiy ----
NODE_ENV=development
# Vergul bilan ajratilgan aniq domenlar (masalan: https://t.me,https://admin.influencex.uz).
# '*' yoki bo'sh - ISHLAB CHIQARISHDA ISHLATILMASIN (2026-07-11 xavfsizlik tahlili, hozircha
# standart '*' - MVP/dev bosqichida qulaylik uchun).
CORS_ORIGIN=*

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=123456:REPLACE_ME
TELEGRAM_BOT_USERNAME=InfluenceXBot
TELEGRAM_WEBHOOK_SECRET=REPLACE_ME_RANDOM_STRING
MINI_APP_URL=https://t.me/InfluenceXBot/app

# ---- Database ----
DATABASE_URL=postgresql://influencex:influencex@localhost:5432/influencex?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT (ichki session tokenlari uchun, Telegram initData tasdiqlangandan keyin) ----
JWT_SECRET=REPLACE_ME_WITH_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ---- S3-compatible storage (avatar/logo/portfolio/chat-attachment yuklash) ----
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=influencex-media
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME
S3_REGION=eu-central-1
# MinIO/Selectel/Yandex Object Storage kabi ko'pchilik S3-compatible provayderlar uchun true qoling;
# haqiqiy AWS S3 uchun false qiling.
S3_FORCE_PATH_STYLE=true
# Ixtiyoriy: agar bucket oldida CDN/alohida public domen bo'lsa (masalan https://cdn.influencex.uz).
# Bo'sh qoldirilsa, publicUrl S3_ENDPOINT/S3_BUCKET/<key> ko'rinishida quriladi.
S3_PUBLIC_URL_BASE=

# ---- To'lov provayderlari (4.5-bo'lim: xizmat-sotib-olish + hamkor-to'lovi, custody emas) ----
# Payme - HAMKORLIK HALI TASDIQLANMAGAN, stub provider (verifyWebhookSignature() = true)
PAYME_MERCHANT_ID=REPLACE_ME
PAYME_SECRET_KEY=REPLACE_ME
# Uzum - HAMKORLIK HALI TASDIQLANMAGAN, stub provider (verifyWebhookSignature() = true)
UZUM_MERCHANT_ID=REPLACE_ME
# Click - HAQIQIY HAMKORLIK BOR, to'liq Merchant/Shop API integratsiyasi ishlaydi.
# Qiymatlarni Click support jamoasidan oling. Webhook URL: <API_URL>/api/v1/escrow/webhook/click
CLICK_MERCHANT_ID=REPLACE_ME
CLICK_SERVICE_ID=REPLACE_ME
CLICK_SECRET_KEY=REPLACE_ME
CLICK_MERCHANT_USER_ID=REPLACE_ME

# ---- AI ----
AI_PROVIDER=openai
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-1.5-flash

# ---- Admin panel ----
ADMIN_PANEL_URL=http://localhost:3001
API_PORT=3000
